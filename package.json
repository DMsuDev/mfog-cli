{
  "name": "modular-framework-offline-generator",
  "version": "1.3.2",
  "description": "Modular CLI for creating projects from multiple frameworks using offline local templates.",
  "keywords": [
    "cli",
    "scaffold",
    "project-generator",
    "create-react-app",
    "template",
    "offline",
    "react",
    "nextjs",
    "vue",
    "angular"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DMsuDev/Modular-Framework-Offline-Generator.git"
  },
  "bugs": {
    "url": "https://github.com/DMsuDev/Modular-Framework-Offline-Generator/issues"
  },
  "homepage": "https://github.com/DMsuDev/Modular-Framework-Offline-Generator#readme",
  "author": "DMsuDev",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mfog": "./bin/cli.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src/",
    "templates/",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "preferGlobal": true,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node ./bin/cli.js",
    "dev": "node ./bin/cli.js"
  },
  "dependencies": {
    "7zip-min": "^2.1.0",
    "@inquirer/prompts": "^8.1.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "figlet": "^1.9.4",
    "gradient-string": "^3.0.0",
    "ora": "^9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "9.30.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3"
  }
}
